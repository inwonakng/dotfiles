{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {},
  "permission": {
    "*": "deny",

    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",

    "bash": {
      "*": "ask",
      "pwd": "allow",
      "uv *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "git status": "allow",
      "git diff": "allow",
      "git diff *": "allow",
    },

    "edit": "deny",
    "task": "deny",
    "todowrite": "allow",
    "skill": "deny",
    "lsp": "deny",
    "question": "deny",

    "webfetch": "deny",
    "websearch": "deny",

    "doom_loop": "ask",
    "external_directory": "ask",
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "color": "warning",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "websearch": "allow",
      },
    },

    "build": {
      "mode": "primary",
      "color": "primary",
      "prompt": "{file:./prompts/build.md}",
      "permission": {
        "edit": "allow",
        "webfetch": "ask",
        "websearch": "deny",
      },
    },
  },
}
